# ─── Supabase ─────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in the publishable key. The admin console reads
# these at build time via Vite's import.meta.env.*
VITE_SUPABASE_URL=https://wxdefpyjntxvowayvvcc.supabase.co

# Preferred — Supabase's new key format (sb_publishable_...)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Legacy — only set this if your project is still issuing JWT-style anon keys
# (eyJ...). If both are set, VITE_SUPABASE_PUBLISHABLE_KEY wins.
# VITE_SUPABASE_ANON_KEY=

# Supabase Storage bucket used by the admin materials page. Create it manually
# in the Supabase dashboard (Storage → New bucket → name = materials).
# The admin uploads under <lang>/<filename>, e.g. materials/vi/whitepaper.pdf.
