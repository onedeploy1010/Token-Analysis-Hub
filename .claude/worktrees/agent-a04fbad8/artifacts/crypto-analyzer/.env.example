# ─── Supabase ─────────────────────────────────────────────────────────────────
# Copy to `.env` and fill in the publishable key. The admin console reads
# these at build time via Vite's import.meta.env.*
VITE_SUPABASE_URL=https://wxdefpyjntxvowayvvcc.supabase.co

# Preferred — Supabase's new key format (sb_publishable_...)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Legacy — only set this if your project is still issuing JWT-style anon keys
# (eyJ...). If both are set, VITE_SUPABASE_PUBLISHABLE_KEY wins.
# VITE_SUPABASE_ANON_KEY=

# Supabase Storage bucket used by the admin materials page. Create it manually
# in the Supabase dashboard (Storage → New bucket → name = materials).
# The admin uploads under <lang>/<filename>, e.g. materials/vi/whitepaper.pdf.

# ─── thirdweb ─────────────────────────────────────────────────────────────────
# Get from https://thirdweb.com/dashboard/settings/api-keys — Client ID is
# public-safe to ship in the frontend bundle. Without it, on-chain reads still
# work via the default RPC but wallet connection UX is degraded.
VITE_THIRDWEB_CLIENT_ID=

# Chain selector for the RUNE presale integration. Valid values:
#   bsc_testnet   (chainId 97, default — testnet addresses already wired)
#   bsc_mainnet   (chainId 56, requires filled VITE_RUNE_*_MAINNET vars)
VITE_RUNE_CHAIN=bsc_testnet

# Mainnet contract addresses (TBD — leave blank until the contracts are deployed)
VITE_RUNE_COMMUNITY_MAINNET=
VITE_RUNE_NODE_PRESELL_MAINNET=

# ─── GraphQL (indexed team data) ──────────────────────────────────────────────
# Base URL of the api-server. Empty = same origin (recommended in prod).
VITE_API_BASE_URL=
